#
# From your own console (not the sandbox), plain uv works:
#

uv run python -m unittest discover -s tests

Useful variants:

# verbose: one line per test
uv run python -m unittest discover -s tests -v

# stop at first failure
uv run python -m unittest discover -s tests -f

# a single file / class / test
uv run python -m unittest tests.test_nfs_cache_locking
uv run python -m unittest tests.test_nfs_cache_metadata.NFSCacheMetadataTests
uv run python -m unittest tests.test_nfs_cache_metadata.NFSCacheMetadataTests.test_warm_hit_skips_full_file_hash_by_default

